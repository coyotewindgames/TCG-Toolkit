# --- App ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173

# --- Database (Render Postgres connection string in prod) ---
DATABASE_URL=postgres://localhost:5432/tcg

# --- Redis (BullMQ + Socket.IO adapter) ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=change-me-in-prod
JWT_ISSUER=tcg-toolkit
JWT_AUDIENCE=tcg-toolkit-api

# --- TCGplayer ---
TCGPLAYER_PUBLIC_KEY=
TCGPLAYER_PRIVATE_KEY=
TCGPLAYER_STORE_KEY=
TCGPLAYER_BASE_URL=https://api.tcgplayer.com

# --- Collectr ---
COLLECTR_API_KEY=
COLLECTR_BASE_URL=https://api.collectr.app

# --- eBay ---
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_BASE_URL=https://api.ebay.com

# --- Square (recommended POS) ---
SQUARE_ACCESS_TOKEN=
SQUARE_APPLICATION_ID=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_NOTIFICATION_URL=https://api.example.com/webhooks/square
SQUARE_ENV=sandbox

# --- Clover (alternative POS) ---
CLOVER_MERCHANT_ID=
CLOVER_API_TOKEN=
CLOVER_WEBHOOK_SIGNING_SECRET=
CLOVER_BASE_URL=https://sandbox.dev.clover.com
