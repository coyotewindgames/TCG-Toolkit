# --- App ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173

# --- Database (Render Postgres connection string in prod) ---
DATABASE_URL=postgresql://neondb_owner:npg_M5o7AOUNWGSv@ep-divine-firefly-aqojzsrs.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require

# --- Redis (BullMQ + Socket.IO adapter) --- 
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=4

# --- Auth ---
JWT_SECRET=change-me-in-prod-at-least-32-chars-min-32-chars
JWT_ISSUER=tcg-toolkit
JWT_AUDIENCE=tcg-toolkit-api
JWT_ACCESS_TTL_SECONDS=3600
REFRESH_TTL_DAYS=30
REFRESH_COOKIE_NAME=tcg_refresh
# COOKIE_DOMAIN=.example.com

# --- Vault (encrypts third-party creds stored in Postgres) ---
# 32-byte key, base64 or hex.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# WARNING: losing this key makes every stored Clover/TCGapi credential unrecoverable.
CONFIG_ENCRYPTION_KEY=

# --- Clover webhook protocol detail (not a secret) ---
CLOVER_WEBHOOK_SIGNATURE_HEADER=x-clover-signature

# --- First-boot seed only ---
# These are read once by `npm run seed:configs -w @tcg/api` to import existing
# credentials into the encrypted Postgres tables. After seeding, remove them.
# Day-to-day credential management happens in the web app at /settings/integrations.
# TCGAPI_KEY=
# CLOVER_BASE_URL=https://sandbox.dev.clover.com
# CLOVER_ACCESS_TOKEN=
# CLOVER_MERCHANT_ID=


# CLOVER_WEBHOOK_SIGNING_SECRET=

# --- Observability ---
SENTRY_DSN=

# --- Email (password reset, future notifications) ---
# In dev, leave RESEND_API_KEY blank: the reset link will be printed to the
# API terminal AND appended to apps/api/.tmp/dev-emails.log so you can grab
# it without scrolling. Tail it with:
#   Get-Content -Wait apps/api/.tmp/dev-emails.log
#
# To send real emails from dev to your inbox:
#   1. Create a free account at https://resend.com
#   2. From the dashboard → API Keys → generate one
#   3. Paste it here as RESEND_API_KEY
#   4. Without a verified domain you MUST keep MAIL_FROM as the default
#      `onboarding@resend.dev` AND you can only send to the email address you
#      registered with Resend. Add your own domain in the Resend dashboard to
#      send to any recipient.
RESEND_API_KEY=
MAIL_FROM=TCG Toolkit <onboarding@resend.dev>

# Absolute URL of the web app, used inside emails (password reset link, etc.).
APP_BASE_URL=http://localhost:5173
