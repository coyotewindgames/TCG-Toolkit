# --- App ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173

# --- Database (Render Postgres connection string in prod) ---
DATABASE_URL=postgres://localhost:5432/tcg

# --- Redis (BullMQ + Socket.IO adapter) ---
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=4

# --- Auth ---
JWT_SECRET=change-me-in-prod-at-least-16-chars
JWT_ISSUER=tcg-toolkit
JWT_AUDIENCE=tcg-toolkit-api
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TTL_DAYS=30
REFRESH_COOKIE_NAME=tcg_refresh
# COOKIE_DOMAIN=.example.com

# --- TCGapi.dev (catalog + pricing; exclusive source) ---
# Real base path includes /v1; the client tolerates either form.
TCGAPI_BASE_URL=https://api.tcgapi.dev/v1
# Sign up at https://tcgapi.dev/dashboard. Format: tcg_live_xxxxxxxx
TCGAPI_KEY=

# --- Clover (POS, exclusive payment processor) ---
CLOVER_BASE_URL=https://sandbox.dev.clover.com
CLOVER_ACCESS_TOKEN=
CLOVER_MERCHANT_ID=
CLOVER_WEBHOOK_SIGNING_SECRET=

# --- Observability ---
SENTRY_DSN=
