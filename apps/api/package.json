{
  "name": "@tcg/api",
  "version": "0.1.0",
  "private": true,
  "description": "Express API for the TCG Toolkit: inventory, POS checkout, trade-ins, real-time events.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch --env-file=.env src/server/main.ts",
    "start": "node dist/server/main.js",
    "lint": "echo 'no lint configured'",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx --env-file=.env src/db/migrate.ts",
    "worker": "tsx --env-file=.env src/jobs/worker.ts",
    "backfill:sku-barcodes": "tsx --env-file=.env src/scripts/backfill-sku-barcodes.ts",
    "seed:configs": "tsx --env-file=.env src/scripts/seed-configs-from-env.ts",
    "bootstrap:owner": "tsx --env-file=.env src/scripts/bootstrap-owner.ts",
    "set:password": "tsx --env-file=.env src/scripts/set-password.ts"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "@tcg/shared": "*",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.16.5",
    "@types/passport": "^1.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pdfkit": "^0.13.4",
    "@types/pg": "^8.11.10",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.13.0",
    "bwip-js": "^4.5.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.15.0",
    "pg": "^8.13.0",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "socket.io": "^4.8.0",
    "typescript": "^5.5.4",
    "vite": "8.0.16",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.1",
    "vitest": "^4.1.8"
  }
}
