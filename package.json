{
  "name": "tcg-toolkit",
  "private": true,
  "version": "0.1.0",
  "description": "TCG store inventory & checkout system — monorepo (Express API + React PWA + shared types).",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "npm run test --workspaces --if-present",
    "dev:api": "npm run dev --workspace=@tcg/api",
    "dev:web": "npm run dev --workspace=@tcg/web",
    "db:generate": "npm run db:generate --workspace=@tcg/api",
    "db:migrate": "npm run db:migrate --workspace=@tcg/api"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.4"
  },
  "optionalDependencies": {
    "@esbuild/win32-x64": "^0.28.0"
  },
  "dependencies": {
    "recharts": "^3.8.1"
  }
}
